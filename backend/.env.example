# ─── NumericaLab Backend — Environment Variables ─────────────────────────────
#
# Copy this file to .env for local development.
# On Render (Web Service), set these under Environment → Environment Variables.
#
# NumericaLab uses no database — all computation is in-memory.

# ── Algorithm limits ──────────────────────────────────────────────────────────
MAX_ITERATIONS=1000
DEFAULT_TOLERANCE=1e-8
FUNCTION_EVAL_TIMEOUT=5

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# In production, replace the Render frontend URL with your actual deployment URL.
#
# Development default (set automatically if this variable is absent):
#   http://localhost:5173,http://127.0.0.1:5173
#
# Production example:
#   ALLOWED_ORIGINS=https://numericalab.onrender.com
#
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
