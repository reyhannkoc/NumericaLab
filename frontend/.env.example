# ─── NumericaLab Frontend — Environment Variables ────────────────────────────
#
# Copy this file to .env.local for local development.
# On Render (Static Site), set these under Environment → Environment Variables.
#
# VITE_API_BASE_URL
#   Leave blank in development — Vite's dev proxy routes /api → localhost:8000.
#   In production, set this to your Render backend service URL (no trailing slash,
#   no /api suffix — the suffix is added automatically by src/services/api.ts).
#
#   Example (production):
#     VITE_API_BASE_URL=https://numericalab-api.onrender.com
#
VITE_API_BASE_URL=
